# Gateway 构建阶段
FROM maven:3.9-eclipse-temurin-17 AS builder
WORKDIR /app

COPY pom.xml .
COPY unimarket-gateway/pom.xml unimarket-gateway/

RUN mvn dependency:go-offline -B -pl unimarket-gateway

COPY . .
RUN mvn clean package -DskipTests -pl unimarket-gateway -am

# Gateway 运行阶段
FROM eclipse-temurin:17-jre-alpine
WORKDIR /app

COPY --from=builder /app/unimarket-gateway/target/*.jar app.jar

RUN apk add --no-cache tzdata && \
    cp /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone

EXPOSE 8090

ENTRYPOINT ["java", "-jar", "-Xms256m", "-Xmx512m", "-Dfile.encoding=UTF-8", "app.jar"]
